<?xml version="1.0" encoding="utf-8"?>
<!-- This is the layout for EACH ITEM WITHIN the detailed order list inside OrderDetailActivity -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="4dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/text_view_item_quantity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 x"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/text_primary_dark"/>

    <TextView
        android:id="@+id/text_view_item_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:text="Delicious Food Item Name"
        android:textSize="14sp"
        android:textColor="@color/text_primary_dark"/>

    <TextView
        android:id="@+id/text_view_item_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹100.00"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary_dark"/>
</LinearLayout>
