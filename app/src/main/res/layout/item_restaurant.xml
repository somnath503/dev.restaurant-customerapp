<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Restaurant Image -->
        <ImageView
            android:id="@+id/iv_restaurant_image"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/restuarant"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@string/restaurant_image_desc" />

        <!-- Restaurant Name -->
        <TextView
            android:id="@+id/tv_restaurant_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            tools:text="Restaurant Name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_restaurant_image"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Restaurant Address -->
        <TextView
            android:id="@+id/tv_restaurant_address"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            tools:text="123 Main St, City, State"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_restaurant_image"
            app:layout_constraintTop_toBottomOf="@id/tv_restaurant_name" />

        <!-- Restaurant Phone -->
        <TextView
            android:id="@+id/tv_restaurant_phone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            tools:text="Phone: +1 (123) 456-7890"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_restaurant_image"
            app:layout_constraintTop_toBottomOf="@id/tv_restaurant_address" />

        <!-- Restaurant Description (Snippet) -->
        <TextView
            android:id="@+id/tv_restaurant_description_snippet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="A brief description of the restaurant. Long text will be truncated."
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_restaurant_image"
            app:layout_constraintTop_toBottomOf="@id/tv_restaurant_phone" />

        <!-- REMOVED: tv_cuisine and tv_rating as they are not in backend DTO -->
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>