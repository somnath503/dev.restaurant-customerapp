<?xml version="1.0" encoding="utf-8"?>
<!-- This layout is included in MenuActivity and MenuItemDetailActivity -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_view_cart"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#4CAF50"
    app:cardCornerRadius="8dp"
    app:cardElevation="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- This part shows the item count and total price -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_cart_item_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="2 ITEMS" />

            <TextView
                android:id="@+id/tv_cart_total_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                tools:text="₹350.50" />
        </LinearLayout>

        <!-- FIX: This button takes the user to the full cart screen -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_go_to_cart"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Go to Cart"
            android:textColor="@color/white"
            app:icon="@drawable/ic_arrow_forward"
            app:iconTint="@color/white"
            app:iconGravity="end" />

        <!-- FIX: This button places the order directly (only visible for 1 item) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_place_order_directly"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Place Order"
            android:textColor="@color/white"
            app:icon="@drawable/ic_arrow_forward"
            app:iconTint="@color/white"
            app:iconGravity="end"
            android:visibility="gone" /> <!-- Hidden by default -->

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
